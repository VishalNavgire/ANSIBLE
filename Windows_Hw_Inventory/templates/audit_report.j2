RAM (GB): {{ audit.Hardware.RAM_GB }}

--- OS Info ---
Product: {{ audit.RegistryConfig.ProductName }}
Version: {{ audit.RegistryConfig.DisplayVersion }}
Build: {{ audit.RegistryConfig.CurrentBuild }}

--- User Profiles ---
{% for user in audit.UserProfiles %}
- {{ user.ProfilePath }} ({{ user.SID }})
{% endfor %}

--- Local Administrators ---
{% if audit.LocalAdmins is string %}
{{ audit.LocalAdmins }}
{% else %}
{% for admin in audit.LocalAdmins %}
- {{ admin.Name }} ({{ admin.ObjectClass }})
{% endfor %}
{% endif %}

--- Scheduled Tasks ---
{% for task in audit.ScheduledTasks %}
- {{ task.TaskName }} ({{ task.TaskPath }})
{% endfor %}

--- Entra ID Status ---
{{ audit.EntraIDStatus }}


--- Installed Applications ---
{% if audit.InstalledApps | length > 0 %}
{% for app in audit.InstalledApps[:20] %}
- {{ app.DisplayName }} ({{ app.DisplayVersion | default('N/A') }}) - {{ app.Publisher | default('Unknown') }}
{% endfor %}
{% else %}
No applications found
{% endif %}

--- Recent Windows Updates ---
{% if audit.Updates | length > 0 %}
{% for update in audit.Updates[:10] %}
- {{ update.HotFixID }} | {{ update.Description }} | Installed: {{ update.InstalledOn }}
{% endfor %}
{% else %}
No updates found
{% endif %}

--- Stopped Services ---
{% if audit.StoppedServices | length == 0 %}
No stopped services found
{% else %}
{% for svc in audit.StoppedServices[:10] %}
- {{ svc.Name }} ({{ svc.DisplayName }}) - StartType: {{ svc.StartType }}
{% endfor %}
{% endif %}

--- High CPU Processes ---
{% for proc in audit.HighResourceProcess.TopCPU %}
- {{ proc.Name }} (PID: {{ proc.Id }}) - CPU Time: {{ proc.CPU }}
{% endfor %}

--- High Memory Processes ---
{% for proc in audit.HighResourceProcess.TopMemory %}
- {{ proc.Name }} (PID: {{ proc.Id }}) - Memory: {{ proc.MemoryMB }} MB
{% endfor %}